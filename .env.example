# =============================================================================
# ARL Airport Platform — Environment Variables
# NEVER commit .env to version control.
# =============================================================================

NEXT_PUBLIC_SITE_URL=https://localhost
# Optional comma-separated extra CORS/CSRF origins. NEXT_PUBLIC_SITE_URL remains canonical first.
# Prefer this variable for new deployments.
ADDITIONAL_ALLOWED_ORIGINS=
# Legacy alias — still honored for backward compatibility with existing deployments.
# New deployments should use ADDITIONAL_ALLOWED_ORIGINS above instead.
# NEXT_PUBLIC_SITE_URLS=https://localhost,https://airport.example

# Long random secret for Payload JWT signing (min 32 chars)
# Generate: openssl rand -base64 48
PAYLOAD_SECRET=CHANGE_ME_USE_openssl_rand_base64_48

# Production: Use Supabase connection pooler (PgBouncer, port 6543) for app traffic.
# This is REQUIRED for horizontal scaling — direct connections will exhaust the pool.
# Migrations use DATABASE_DIRECT_URL (port 5432) which bypasses PgBouncer.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-eu-west-1.supabase.com:5432/postgres
# Required in production for remote Postgres TLS verification. The app refuses
# to boot without this when NODE_ENV=production outside standalone build output.
DATABASE_CA_CERT=

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Optional server-side runtime override. Avoids relying on baked NEXT_PUBLIC values in standalone builds.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY
SUPABASE_S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_KEY
SUPABASE_S3_ENDPOINT=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=eu-west-1
SUPABASE_STORAGE_BUCKET_MEDIA=arl-public-media
SUPABASE_STORAGE_BUCKET_DOCUMENTS=arl-protected-docs


REVALIDATE_SECRET=CHANGE_ME_USE_openssl_rand_hex_32
VISITOR_HASH_SALT=CHANGE_ME_USE_openssl_rand_base64_32

# Redis (Upstash) — REQUIRED in production for shared rate limiting and API caching.
# Without these, each app instance uses in-memory fallbacks (no cross-instance guarantees).
# Create a database at https://console.upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REST_TOKEN


FLIGHT_PROVIDER_MODE=airlabs
FLIGHT_PROVIDER_LABEL=AirLabs
FLIGHT_PROVIDER_ENDPOINT=https://airlabs.co/api/v9
FLIGHT_PROVIDER_API_KEY=YOUR_AIRLABS_API_KEY
# Optional: set alongside API_KEY to authenticate with AirLabs' time-bound signed
# signature (api_id:timestamp:md5(timestamp:api_key)) instead of sending the raw
# api_key in the query string. Find the id next to your key in the AirLabs dashboard.
FLIGHT_PROVIDER_API_ID=
FLIGHT_PROVIDER_IATA_CODE=RRG
FLIGHT_PROVIDER_AIRLINE_FILTER=MK,UU

# Weather: Open-Meteo (no API key needed). Override endpoint for self-hosted instances.
WEATHER_PROVIDER_LABEL=Open-Meteo Forecast API
WEATHER_PROVIDER_ENDPOINT=https://api.open-meteo.com/v1/forecast
WEATHER_PROVIDER_LATITUDE=-19.757778
WEATHER_PROVIDER_LONGITUDE=63.361389
WEATHER_PROVIDER_TIMEZONE=Indian/Mauritius

# Error Monitoring (Sentry) — REQUIRED in production for error aggregation and alerting.
# Create a project at https://sentry.io and copy the DSN.
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN

# Production image used by docker-compose.prod.yml.
APP_IMAGE=ghcr.io/arl-plaine-corail-airport/arl-airport-platform:latest

# Production domain - used by Nginx conf template and Let's Encrypt.
# Leave blank for local/staging (uses self-signed certs).
DOMAIN=
CERTBOT_EMAIL=

# Status endpoint auth - protects /api/status from public access.
# Generate: openssl rand -base64 24
STATUS_SECRET=CHANGE_ME_USE_openssl_rand_base64_24

# Automated backups - retention period in days.
BACKUP_RETENTION_DAYS=30

# Analytics page-view retention.
PAGE_VIEW_RETENTION_DAYS=90
PAGE_VIEW_RETENTION_BATCH_SIZE=10000

# Deploy failure notifications - Discord or Slack incoming webhook URL.
# Optional. If not set, deploy failures are only visible in GitHub Actions.
DEPLOY_WEBHOOK_URL=

# Alert webhook - Discord or Slack incoming webhook URL for health/backup failure alerts.
# Optional. If not set, alerts are only logged to stderr/files.
ALERT_WEBHOOK_URL=
