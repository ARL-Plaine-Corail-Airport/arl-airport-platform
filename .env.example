# =============================================================================
# ARL Airport Platform — Environment Variables
# NEVER commit .env to version control.
# =============================================================================

NEXT_PUBLIC_SITE_URL=https://localhost:3000

# Long random secret for Payload JWT signing (min 32 chars)
# Generate: openssl rand -base64 48
PAYLOAD_SECRET=CHANGE_ME_USE_openssl_rand_base64_48

# Production: Use Supabase connection pooler (PgBouncer, port 6543) for app traffic.
# This is REQUIRED for horizontal scaling — direct connections will exhaust the pool.
# Migrations use DATABASE_DIRECT_URL (port 5432) which bypasses PgBouncer.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-eu-west-1.supabase.com:5432/postgres

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY
SUPABASE_S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_KEY
SUPABASE_S3_ENDPOINT=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=eu-west-1
SUPABASE_STORAGE_BUCKET_MEDIA=arl-public-media
SUPABASE_STORAGE_BUCKET_DOCUMENTS=arl-protected-docs


REVALIDATE_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# Redis (Upstash) — REQUIRED in production for shared rate limiting and API caching.
# Without these, each app instance uses in-memory fallbacks (no cross-instance guarantees).
# Create a database at https://console.upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REST_TOKEN


FLIGHT_PROVIDER_MODE=airlabs
FLIGHT_PROVIDER_LABEL=AirLabs
FLIGHT_PROVIDER_ENDPOINT=https://airlabs.co/api/v9
FLIGHT_PROVIDER_API_KEY=YOUR_AIRLABS_API_KEY
FLIGHT_PROVIDER_IATA_CODE=RRG
FLIGHT_PROVIDER_AIRLINE_FILTER=MK,UU

# Weather: Open-Meteo (no API key needed). Override endpoint for self-hosted instances.
WEATHER_PROVIDER_ENDPOINT=https://api.open-meteo.com/v1/forecast
WEATHER_PROVIDER_LATITUDE=-19.757778
WEATHER_PROVIDER_LONGITUDE=63.361389
WEATHER_PROVIDER_TIMEZONE=Indian/Mauritius

# Error Monitoring (Sentry) — REQUIRED in production for error aggregation and alerting.
# Create a project at https://sentry.io and copy the DSN.
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN
